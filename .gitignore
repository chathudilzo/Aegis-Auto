# ==========================================
# 1. Python Telemetry Server Ignores
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
ENV/
*.env

# ==========================================
# 2. Flutter Frontend Subfolder Ignores
# ==========================================
